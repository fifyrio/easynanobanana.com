# KIE API Configuration (for async image generation)
KIE_API_TOKEN=sk-kie-your-actual-token-here
KIE_CALLBACK_URL=https://easynanobanana.com/api/kie/callback

# KIE Video (Seedance 2 Fast) callback URL — separate from image callback.
# For local POC testing with ngrok, set this to your ngrok https URL, e.g.
# KIE_VIDEO_CALLBACK_URL=https://abcd-1234.ngrok-free.app/api/video/callback
KIE_VIDEO_CALLBACK_URL=https://easynanobanana.com/api/video/callback

# OpenRouter API Configuration (legacy - can be removed after migration)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
# ===== Waffo Pancake Payments =====
# PAYMENT_ENV switches between test/production credential sets
PAYMENT_ENV=test

# Private key: base64-encoded PEM (recommended) or raw PEM with literal \n.
# Get with: base64 -i waffo-private-key.pem | tr -d '\n'
WAFFO_TEST_MERCHANT_ID=MER_xxx
WAFFO_TEST_STORE_ID=STO_xxx
WAFFO_TEST_PRIVATE_KEY_BASE64=
WAFFO_TEST_BASIC_PRODUCT_ID=PROD_xxx
WAFFO_TEST_PRO_PRODUCT_ID=PROD_xxx
WAFFO_TEST_MAX_PRODUCT_ID=PROD_xxx

WAFFO_PROD_MERCHANT_ID=
WAFFO_PROD_STORE_ID=
WAFFO_PROD_PRIVATE_KEY_BASE64=
WAFFO_PROD_BASIC_PRODUCT_ID=
WAFFO_PROD_PRO_PRODUCT_ID=
WAFFO_PROD_MAX_PRODUCT_ID=

WAFFO_WEBHOOK_TEST_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
WAFFO_WEBHOOK_PROD_PUBLIC_KEY=
