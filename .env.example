# KIE API Configuration (for async image generation)
KIE_API_TOKEN=sk-kie-your-actual-token-here
KIE_CALLBACK_URL=https://easynanobanana.com/api/kie/callback

# KIE Video (Seedance 2 Fast) callback URL — separate from image callback.
# For local POC testing with ngrok, set this to your ngrok https URL, e.g.
# KIE_VIDEO_CALLBACK_URL=https://abcd-1234.ngrok-free.app/api/video/callback
KIE_VIDEO_CALLBACK_URL=https://easynanobanana.com/api/video/callback

# OpenRouter API Configuration (legacy - can be removed after migration)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000